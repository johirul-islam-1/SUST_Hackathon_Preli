{
  "name": "queuestorm-investigator",
  "version": "1.0.0",
  "description": "QueueStorm Investigation Engine — deterministic ticket analysis pipeline",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "samples": "tsx scripts/run-samples.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
